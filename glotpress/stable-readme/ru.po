#. Found in changelog list item.
#, gp-priority: low
msgid "Extracted reusable <code>swifttrap_mailtrap_get_account_id()</code> with transient caching"
msgstr "Вынесена переиспользуемая функция <code>swifttrap_mailtrap_get_account_id()</code> с кэшированием через transient"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added <code>swifttrap_mailtrap_custom_variables</code> filter for email tracking metadata"
msgstr "Добавлен фильтр <code>swifttrap_mailtrap_custom_variables</code> для метаданных отслеживания писем"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added <code>swifttrap_mailtrap_template</code> filter for Mailtrap template support"
msgstr "Добавлен фильтр <code>swifttrap_mailtrap_template</code> для поддержки шаблонов Mailtrap"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added suppression list (bounces, complaints, unsubscribes) on Stats page"
msgstr "Добавлен список блокировок (возвраты, жалобы, отписки) на странице статистики"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added sending domain verification status on Stats page"
msgstr "Добавлен статус верификации домена отправки на странице статистики"

#. Found in changelog list item.
#, gp-priority: low
msgid "Better WordPress Coding Standards compliance"
msgstr "Улучшено соответствие WordPress Coding Standards"

#. Found in changelog list item.
#, gp-priority: low
msgid "Improved PHPDoc headers across all files"
msgstr "Улучшены заголовки PHPDoc во всех файлах"

#. Found in changelog list item.
#, gp-priority: low
msgid "Fixed $_GET sanitization with proper wp_unslash() and phpcs annotations"
msgstr "Исправлена санитизация $_GET с корректным использованием wp_unslash() и аннотаций phpcs"

#. Found in changelog list item.
#, gp-priority: low
