msgstr "Añadido el filtro <code>swifttrap_mailtrap_template</code> para compatibilidad con plantillas de Mailtrap"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added suppression list (bounces, complaints, unsubscribes) on Stats page"
msgstr "Añadida la lista de supresión (rebotes, quejas, bajas) en la página de estadísticas"

#. Found in changelog list item.
#, gp-priority: low
