msgstr "Extraída la función reutilizable <code>swifttrap_mailtrap_get_account_id()</code> con caché de transients"

#. Found in changelog list item.
#, gp-priority: low
msgid "Added <code>swifttrap_mailtrap_custom_variables</code> filter for email tracking metadata"
msgstr "Añadido el filtro <code>swifttrap_mailtrap_custom_variables</code> para metadatos de seguimiento de correo"

#. Found in changelog list item.
#, gp-priority: low
